# Chiave segreta Flask (cambia in produzione!)
GUFOBOX_SECRET_KEY=change-me-in-production

# API Key OpenAI (opzionale, per il Gufetto AI e TTS online)
# Imposta questa variabile d'ambiente OPPURE configurala dal pannello admin
# (Gufetto AI -> Impostazioni AI). Non committare mai la chiave nel codice.
OPENAI_API_KEY=

# PIN Admin di default
GUFOBOX_ADMIN_PIN=0000

# Cookie Settings
GUFOBOX_COOKIE_SECURE=0
GUFOBOX_COOKIE_SAMESITE=Lax

# Hotspot WiFi
GUFOBOX_HOTSPOT_SSID=GUFOBOX
GUFOBOX_HOTSPOT_PASS=gufobox123
GUFOBOX_HOTSPOT_CONN=GUFOBOX-AP

# === Voce offline (Piper TTS) ===
# Percorso al binario piper (default: "piper" cerca nel PATH di sistema)
# Scarica da: https://github.com/rhasspy/piper/releases
#   RPi 4/5 (64-bit): piper_linux_aarch64.tar.gz
#   RPi 3 (32-bit):   piper_linux_armv7l.tar.gz
# Dopo aver estratto: sudo cp piper /usr/local/bin/
# GUFOBOX_PIPER_BIN=piper

# Cartella dove sono salvati i modelli voce .onnx
# (default: data/piper_voices/ nella directory del progetto)
# Scarica i modelli da: https://huggingface.co/rhasspy/piper-voices
# Esempio voce italiana: it_IT-paola-medium.onnx + it_IT-paola-medium.onnx.json
# GUFOBOX_PIPER_VOICES_DIR=/home/gufobox/piper_voices
